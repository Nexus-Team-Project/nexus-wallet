# nexus-wallet client configuration. Copy this file to .env.local for
# local development. Production values live in Railway.
#
# Spec: docs/superpowers/specs/2026-05-25-nexus-wallet-auth-design.md

# Backend API base URL. Local dev defaults to nexus-website/backend on 3001.
VITE_API_URL=http://localhost:3001

# Website URL used when the wallet redirects to the marketing/login site.
VITE_WEBSITE_URL=http://localhost:3000

# Admin dashboard. The wallet RouterScreen redirects privileged-role
# users here via the /api/auth/create-code one-time SSO handoff.
VITE_DASHBOARD_URL=http://localhost:5174

# Google Identity Services client id. Same value as the backend
# GOOGLE_CLIENT_ID. Add https://wallet.nexus-payment.com to the
# authorized JS origins in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=
